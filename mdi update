<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>MDI SYSTEM</title>

<style>
/* === ORIGINAL STYLE TIDAK DIUBAH === */
*{box-sizing:border-box;}
body{margin:0;font-family:Arial;background:#2f4fa3;}

header{
background:#1a0dab;color:white;padding:15px 20px;
display:flex;justify-content:space-between;align-items:center;
}

.header-left{display:flex;align-items:center;gap:10px;}
.header-left img{width:50px;}

.header-title{font-size:22px;font-weight:bold;}
.header-sub{font-size:12px;}

.header-right{text-align:right;}
.header-right .big{font-size:20px;font-weight:bold;}
.header-right .small{font-size:14px;}

.login-wrapper{
display:flex;justify-content:center;align-items:center;
height:calc(100vh - 100px);
}

.login-box{
width:100%;max-width:400px;background:#e5e7eb;
padding:30px;border-radius:15px;text-align:center;
}

.login-box input{
width:100%;padding:12px;margin-bottom:15px;
border-radius:8px;border:1px solid #60a5fa;
}

.login-box button{
width:100%;padding:12px;background:#1a0dab;
color:white;border:none;border-radius:8px;cursor:pointer;
}

.popup{
position:fixed;top:50%;left:50%;
transform:translate(-50%,-50%);
background:white;padding:25px;border-radius:12px;
box-shadow:0 5px 20px rgba(0,0,0,0.4);
text-align:center;z-index:999;
}

.popup button{
margin-top:15px;padding:8px 20px;
background:#1a0dab;color:white;border:none;border-radius:8px;
}

.footer{
position:fixed;bottom:10px;width:100%;
text-align:center;color:white;font-size:12px;
}

.layout{display:flex;min-height:calc(100vh - 100px);}

.sidebar{
width:260px;
background:linear-gradient(180deg,#5fa8dc,#4aa0d4);
padding:20px;border-radius:0 20px 20px 0;
}

.sidebar-title{text-align:center;margin-bottom:20px;}
.title-main{color:#0b2fa5;font-weight:bold;}
.title-sub{color:white;font-size:18px;}

.menu{
background:#7cc5c9;color:black;padding:14px;
margin-bottom:12px;border-radius:12px;border:none;
cursor:pointer;width:100%;
transition:0.3s;
}

.menu.active{
background:#2c4fa3;
color:white;
}

.refresh-btn{
background:#1a0dab;color:white;padding:14px;
border-radius:12px;border:none;width:100%;
cursor:pointer;
}

.content{
flex:1;padding:30px;background:#2f4fa3;color:white;
}

.dashboard-title{
font-size:22px;font-weight:bold;margin-bottom:25px;
}

.card{
background:#dcdcdc;padding:20px;border-radius:15px;
margin-bottom:20px;display:flex;
justify-content:space-between;align-items:center;
}

.card-left h3{margin:0;color:black;}
.card-left p{margin:5px 0 0;color:#333;}

.btn-primary{
background:#2b0ab3;color:white;
padding:12px 35px;border:none;border-radius:12px;
cursor:pointer;
}

.pin-box{
display:flex;
flex-direction:column;
align-items:flex-end;
gap:10px;
}

.pin-box input{
padding:10px;border-radius:10px;border:1px solid black;
width:180px;text-align:center;
}

.command-btn{
background:#6ec1c6;padding:15px 40px;
border:none;border-radius:12px;color:black;
cursor:pointer;
}

.hidden{display:none;}

/* === NEW REPORT STYLE === */
.input-full{
width:100%;
padding:12px;
border-radius:12px;
border:2px solid black;
margin-bottom:15px;
background:#dcdcdc;
}

.textarea-full{
width:100%;
height:120px;
padding:12px;
border-radius:12px;
border:2px solid black;
margin-bottom:15px;
background:#dcdcdc;
}

.report-grid{
display:flex;
gap:20px;
}

.left-box{
flex:1;
background:#dcdcdc;
padding:10px;
border-radius:15px;
}

.left-box textarea{
width:100%;
height:200px;
border:none;
background:transparent;
resize:none;
}

.right-box{
width:300px;
display:flex;
flex-direction:column;
gap:15px;
}

.full-btn{
width:100%;
}
</style>
</head>

<body>

<header>
<div class="header-left">
<img src="https://raw.githubusercontent.com/jvxtgzg/MDI-SYSTEMS/main/BRO%20LOGO.png">
<div>
<div class="header-title">MDI SYSTEM</div>
<div class="header-sub">Mobile Data Investigation</div>
</div>
</div>

<div class="header-right">
<div class="big">BUREAU OF RESPONSE OPERATIVE</div>
<div class="small">DEPARTMENT OF JUSTICE</div>
</div>
</header>

<!-- LOGIN -->
<div id="loginScreen" class="login-wrapper">
<div class="login-box">
<h2>Agent Login</h2>
<input id="codeName" placeholder="Code Name">
<input id="callSign" placeholder="Callsign">
<button onclick="login()">Login</button>
</div>
</div>

<!-- POPUP -->
<div id="errorPopup" class="popup hidden">
<h3 id="popupText">Data Tidak Cocok</h3>
<button onclick="closePopup()">X</button>
</div>

<div class="footer">©2026 BRO MDI SYSTEM</div>

<!-- APP -->
<div id="app" class="hidden">
<div class="layout">

<div class="sidebar">
<div class="sidebar-title">
<div id="agentName" class="title-main">AGENTS NAME</div>
<div id="agentRank" class="title-sub">RANK</div>
</div>

<button id="btn-dashboard" class="menu active" onclick="showPage('dashboardPage','btn-dashboard')">Dashboard</button>
<button id="btn-report" class="menu" onclick="showPage('reportPage','btn-report')">New Report</button>
<button id="btn-files" class="menu" onclick="setActive('btn-files')">Files</button>
<button id="btn-contribution" class="menu" onclick="setActive('btn-contribution')">Contribution</button>

<button class="refresh-btn" onclick="loadPIN()">Refresh PIN</button>
</div>

<div class="content">

<!-- DASHBOARD -->
<div id="dashboardPage">

<div class="dashboard-title">DASHBOARD</div>

<div class="card">
<div class="card-left">
<h3>Agents Data BRO</h3>
<p>Periksa Data Rahasia Anda</p>
</div>
<button class="btn-primary" onclick="openAgentData()">OPEN</button>
</div>

<div class="card">
<div class="card-left">
<h3>Security PIN</h3>
<p>Gunakan PIN Untuk Akses</p>
</div>

<div class="pin-box">
<input id="pinField" type="password" readonly>
<button class="btn-primary" onclick="togglePIN()">View PIN</button>
</div>

</div>

<div style="margin-top:20px;">
<button class="command-btn" onclick="openCommandPanel()">Command Panel</button>
<button id="updatePinBtn" class="btn-primary hidden" onclick="goToSpreadsheet()">Update PIN</button>
</div>

</div>

<!-- NEW REPORT -->
<div id="reportPage" class="hidden">

<!-- HEADER FIX -->
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
  <div class="dashboard-title">NEW REPORT</div>

  <div id="caseIdDisplay" style="
    background:#dcdcdc;
    color:black;
    padding:10px 20px;
    border-radius:12px;
    font-weight:bold;
    border:2px solid black;
  ">
    CASE ID: -
  </div>
</div>

<input id="missionInput" class="input-full" placeholder="Mission Name">
<input id="dateInput" class="input-full" placeholder="Date">

<textarea id="detailInput" class="textarea-full" placeholder="Mission Detail"></textarea>

<div class="report-grid">

<div class="left-box">
<textarea id="intelInput" placeholder="Intel Info"></textarea>
</div>

<div class="right-box">
<input id="agentsInput" class="input-full" placeholder="Agents">
<input id="evidenceInput" class="input-full" placeholder="Evidence Link">

<button class="btn-primary full-btn" onclick="saveReport()">Save Report</button>
</div>

</div>

</div>

</div>
</div>
</div>

<script>

/* NAVIGATION */
function showPage(pageId, btnId){
dashboardPage.classList.add("hidden");
reportPage.classList.add("hidden");

document.getElementById(pageId).classList.remove("hidden");

document.querySelectorAll(".menu").forEach(btn=>{
btn.classList.remove("active");
});
document.getElementById(btnId).classList.add("active");

/* AUTO GENERATE CASE ID */
if(pageId === "reportPage"){
generateCaseId();
}
}

/* === ORIGINAL SCRIPT (TIDAK DIUBAH) === */
let currentRank="";

function setActive(id){
document.querySelectorAll(".menu").forEach(btn=>{
btn.classList.remove("active");
});
document.getElementById(id).classList.add("active");
}

async function login(){
const code = codeName.value.trim().toUpperCase();
const call = callSign.value.trim();

const res = await fetch("https://docs.google.com/spreadsheets/d/1yVsYlFJkPeIp6p3LApsiW4Ivv_5XihznO7BJLf_VRsY/gviz/tq?tqx=out:json");
const text = await res.text();
const json = JSON.parse(text.substring(text.indexOf("{"), text.lastIndexOf("}")+1));

let foundUser=null;

json.table.rows.forEach(r=>{
let c=(r.c[1]?.v||"").toUpperCase();
let s=(r.c[2]?.v||"");

if(code===c && call===s){
foundUser={
code:c,
division:r.c[3]?.v||"-",
rank:r.c[4]?.v||"-"
};
}
});

if(foundUser){
currentRank=foundUser.rank;
agentName.innerText=foundUser.code+" ("+foundUser.division+")";
agentRank.innerText=foundUser.rank;

loginScreen.classList.add("hidden");
app.classList.remove("hidden");
loadPIN();
}else{
showPopup("Data Tidak Cocok");
}
}

async function loadPIN(){
  try{
    const url = "https://script.google.com/macros/s/AKfycbyR8Src2UFkUnUpoyf7Xa0xsTs1_16QsShvslPF_dBRVClTQnK7LBQv3ArpoPpzsOqQ/exec?action=view";
    const res = await fetch(url);
    const pin = await res.text();

    pinField.value = pin ? pin.trim() : "NO PIN";
  }catch(err){
    console.error(err);
    pinField.value = "ERROR LOAD PIN";
  }
}

function openCommandPanel(){
if(currentRank.toLowerCase().includes("director")){
updatePinBtn.classList.toggle("hidden");
}else{
showPopup("Akses Ditolak: Hanya Director");
}
}

function goToSpreadsheet(){
window.open("https://docs.google.com/spreadsheets/d/1hhNx80P6iydL0ouRqNtsQDx4ajNFIoz7sCnxLlZdeVs/edit","_blank");
}

function showPopup(msg){
popupText.innerText=msg;
errorPopup.classList.remove("hidden");
}

function closePopup(){
errorPopup.classList.add("hidden");
}

function openAgentData(){
window.open("http://bro-membedata-imerp.my.id/","_blank");
}

let pinVisible=false;
async function togglePIN(){

pinVisible = !pinVisible;

if(pinVisible){
pinField.type = "text";
await loadPIN(); // 🔥 ambil PIN dari Apps Script
}else{
pinField.type = "password";
pinField.value = "******";
}

}
/* === NEW REPORT SAVE === */
let currentCaseId = "";

async function generateCaseId(){

const res = await fetch("https://docs.google.com/spreadsheets/d/1yVsYlFJkPeIp6p3LApsiW4Ivv_5XihznO7BJLf_VRsY/gviz/tq?tqx=out:json");
const text = await res.text();
const json = JSON.parse(text.substring(text.indexOf("{"), text.lastIndexOf("}")+1));

let rows = json.table.rows;

let lastNumber = 0;

rows.forEach(r=>{
let id = r.c[0]?.v || "";
if(id.startsWith("BRO-")){
let num = parseInt(id.replace("BRO-",""));
if(num > lastNumber) lastNumber = num;
}
});

let next = lastNumber + 1;
currentCaseId = "BRO-" + String(next).padStart(4,'0');

document.getElementById("caseIdDisplay").innerText = "CASE ID: " + currentCaseId;
}

async function saveReport(){

if(!missionInput.value || !dateInput.value){
showPopup("Mission & Date wajib diisi");
return;
}

let data={
caseId: currentCaseId,
date: dateInput.value,
mission: missionInput.value,
detail: detailInput.value,
intel: intelInput.value,
agents: agentsInput.value,
status: "OPEN",
createdBy: agentName.innerText,
evidence: evidenceInput.value ? [evidenceInput.value] : []
};

await fetch("https://script.google.com/macros/s/AKfycbxkFsuKuIsQl_x5dSgJECX_CRHEb2j8o3AytO4vVq2HDE72C55AdoxLrxMihiuyvlfFuw/exec", {
method: "POST",
headers: {"Content-Type":"application/json"},
body: JSON.stringify(data)
});

showPopup("Report berhasil disimpan");

/* reset */
missionInput.value="";
dateInput.value="";
detailInput.value="";
intelInput.value="";
agentsInput.value="";
evidenceInput.value="";
}

</script>

</body>
</html>
